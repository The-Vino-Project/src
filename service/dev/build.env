# Source our internal variables
. service/dev/vars.env

# Export envs
export NT_PROJECT_ROOT=$NT_PROJECT_ROOT

if [ "$NT_BUILD_SOURCED" != "1" ]
then
    echo "[*] build environment prepared"
    PS1="(VINO) $PS1"
fi

# Indicate that we have been sourced
export NT_BUILD_SOURCED=1
